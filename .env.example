# ─── Database ────────────────────────────────────────────────────────────────
# Local dev points at the docker-compose Postgres. In the cluster, point this at
# the postgres Service instead.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/arena

# ─── Auth (Better Auth) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-me-please-32-bytes
BETTER_AUTH_URL=http://localhost:3000

# ─── API / Web ───────────────────────────────────────────────────────────────
API_PORT=3000
WEB_URL=http://localhost:5173
# Consumed by the web app (Vite) to reach the API
VITE_API_URL=http://localhost:3000

# ─── Google OAuth (social login) ─────────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email (OTP delivery) ────────────────────────────────────────────────────
# Local dev uses Mailpit (docker-compose): SMTP on 1025, web UI on 8025.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Arena <no-reply@arena.local>

# ─── Object storage (MinIO / S3) ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_AVATARS=profile-pics
# Public base URL used to render stored objects back to the browser
MINIO_PUBLIC_URL=http://localhost:9000
